# Secrets — never commit these
.env
.env.local
.env.*.local
config.local.js

# Supabase service-role key (bypasses RLS — must never be committed)
supabase.secret.*
service-role*

# OS junk
.DS_Store
Thumbs.db
desktop.ini
ehthumbs.db

# Editor files
.vscode/settings.json
.idea/
*.suo
*.user

# Node (if build tooling is ever added)
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Backup / temp files
*.bak
*.orig
*.tmp
*.log
